---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Neuroscience-grounded tools for LLM coding harnesses.' } = Astro.props;
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-neutral-950 text-neutral-100 font-mono antialiased min-h-screen">
    <header class="border-b border-neutral-800">
      <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-lg font-semibold tracking-tight text-neutral-50 hover:text-emerald-400 transition-colors">
          cerebral.work
        </a>
        <ul class="flex gap-6 text-sm text-neutral-400">
          <li><a href="/reverie" class="hover:text-emerald-400 transition-colors">reverie</a></li>
          <li><a href="/meshctl" class="hover:text-emerald-400 transition-colors">meshctl</a></li>
          <li><a href="https://github.com/cerebral-work" class="hover:text-emerald-400 transition-colors">github</a></li>
        </ul>
      </nav>
    </header>
    <main class="max-w-4xl mx-auto px-6 py-12">
      <slot />
    </main>
    <footer class="border-t border-neutral-800 mt-24">
      <div class="max-w-4xl mx-auto px-6 py-6 text-xs text-neutral-500 flex justify-between">
        <span>© 2026 cerebral.work</span>
        <span>Built with Astro · Hosted on Cloudflare</span>
      </div>
    </footer>
  </body>
</html>
